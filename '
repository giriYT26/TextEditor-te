//Reads the key 
int readKey(){
  char chr;
  if (read(STDIN_FILENO,&chr,1) != 1) return -1;
  return chr;
}
// process the key
// this below function is the main for the program 
int processkey(char key){
  int end_loop = 0;
  // handles keymovement like up,down,right,left
  if (key == 27){
    int tkey = readKey(); //read the next key after the key is esc 
    if (tkey == 91){ // checking if the key is '[' after the esc is pressed
      tkey = readKey(); //getting the input and checking and validation the userinput
      switch (tkey){
      case 'A': write(STDOUT_FILENO,"\033[A",3); break;
      case 'B': write(STDOUT_FILENO,"\033[B",3); break;
      case 'C': write(STDOUT_FILENO,"\033[C",3); break;
      case 'D': write(STDOUT_FILENO,"\033[D",3); break;
        
      }
    }
  }
  if (key == 17) return 1; // ctrl+q (ASCII val is 17) to quit  
  printf("%c",key);
  fflush(stdout);
  return end_loop;
}

// Enables the Raw Mode 
void enableRawMode(){
  //printf("Enabling Raw Mode");
  tcgetattr(STDIN_FILENO,&original); //getting the terminal's attributes
  rw = original;

  // local flag
  rw.c_lflag &= ~ECHO; // disable echo
  rw.c_lflag &= ~ICANON; // disable line input;
  rw.c_lflag &= ~IEXTEN; // disable extended input processing to prevent runing other shortcuts like ctrl+v;

  //input flag
  rw.c_iflag &= ~IXON; //disable software flow control
  rw.c_iflag &= ~ICRNL; // disable return carrage it convert \r to \n, so we disable it 
  
  //output flag
  rw.c_oflag &= ~(OPOST); // output post processing (transform the output before printing it )
  
  //control flag
  rw.c_cflag |= (CS8);
  //apply the changes to the struct
  tcsetattr(STDIN_FILENO,TCSAFLUSH,&rw);
}
